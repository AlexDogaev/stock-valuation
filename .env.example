# Прод-конфиг. Скопируй в .env и заполни. .env в git НЕ идёт.

# Публичный хост для авто-HTTPS (Caddy/Let's Encrypt).
# Без своего домена — sslip.io: <PUBLIC_IP с дефисами вместо точек>.sslip.io
# напр. для IP 203.0.113.5 →  203-0-113-5.sslip.io
# Со своим доменом — просто укажи его (A-запись должна указывать на сервер).
PUBLIC_HOST=replace-me.sslip.io

# Бета-доступ: per-user логины, через запятую. ОБЯЗАТЕЛЬНО смени пароли.
APP_AUTH=beta1:CHANGE_ME_1,beta2:CHANGE_ME_2,beta3:CHANGE_ME_3

# Ключ Opus — для LLM-кнопок (анализ режима, риск-ШОКа, черновики, обоснования).
# Без него кнопки graceful-выключены (данные из БД остаются).
ANTHROPIC_API_KEY=

# Опционально:
# TINVEST_TOKEN=        # обновление фундаментала из T-Invest (может гео-блок из не-РФ; данные уже в БД)
# TELEGRAM_TOKEN=       # нотификации о смене сигнала/режима
# ANTHROPIC_MODEL=claude-opus-4-8

SCHEDULER_ENABLED=1
DB_PATH=/data/data.sqlite3
